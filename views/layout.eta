<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= it.title %> — CSP Examples</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <%~ it.head ?? "" %>
</head>
<body class="app-body">
  <header class="site-header">
    <a class="site-logo" href="/"><span class="site-logo-accent">csp</span>.examples</a>
    <nav class="site-nav">
      <a class="site-nav-link" href="/">Examples</a>
    </nav>
  </header>
  <main class="site-main"><%~ it.body %></main>
  <% if (it.isReload) { %><script src="/javascripts/reload.js"></script><% } %>
</body>
</html>
