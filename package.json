{
  "name": "csp",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "ts-node bin/server.ts",
    "dev": "ts-node-dev --respawn --transpile-only bin/server.ts",
    "build": "tsc",
    "lint": "eslint src bin",
    "start:prod": "node dist/bin/server.js",
    "test": "playwright test --project=headless",
    "test:ui": "playwright test --project=ui"
  },
  "dependencies": {
    "express": "^4.22.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/chokidar": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "chokidar": "^5.0.0",
    "eslint": "^10.5.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
